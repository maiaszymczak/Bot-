# Discord
DISCORD_TOKEN=
GUILD_ID=

# Google Sheets
SHEET_ID=

# Optionnel (quota Google Sheets / anti-429)
# Augmente ces TTL si tu vois des erreurs 429 (quota de lectures/minute).
# Cache des cellules de l'onglet JOUEURS (secondes)
# SHEET_CACHE_TTL_SECONDS=60
# Cache doc/metadata (ms)
# SHEET_DOC_CACHE_TTL_MS=900000
# Cache des lectures de l'onglet ACTIVITES (ms)
# SHEET_ACTIVITIES_CACHE_TTL_MS=60000

# Auth Google (choisis une option)
# Option 1 (simple): mets le fichier JSON service account ici: bsg/credentials.json
# Option 2: pointe vers le fichier JSON (chemin absolu recommandé côté serveur)
# GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/to/service_account.json

# Optionnel (rôle Discord)
# BSG_MEMBER_ROLE_ID=
# BSG_MEMBER_ROLE_NAME=bsg membre

# Optionnel (staff pour /checknames)
# Liste d'IDs de rôles séparés par des virgules/espaces.
# BSG_STAFF_ROLE_IDS=123,456,789

# Optionnel (Discord anti-rate-limit)
# `guild.members.fetch()` sans argument déclenche des requêtes Gateway opcode 8,
# facilement rate-limit sur les gros serveurs / redémarrages.
# Startup sync (sheet <- rôle)
# BSG_STARTUP_SYNC_ENABLED=true
# BSG_STARTUP_SYNC_MODE=rest
# - rest   : sync complet via REST (recommandé, évite opcode 8)
# - cache  : utilise uniquement le cache Discord (peut être incomplet)
# - gateway: force `guild.members.fetch()` (peut rate-limit opcode 8)
# - off    : pas de sync au démarrage
# /checkmembers (force le fetch massif si tu veux un count exact)
# BSG_CHECKMEMBERS_FETCH_ALL_MEMBERS=false

# Optionnel (format sheet)
# SHEET_HEADER_ROWS=3

# Optionnel (auto suppression des messages, 30..3600)
# AUTO_DELETE_SECONDS=300
